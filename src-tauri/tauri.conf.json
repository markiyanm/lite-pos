{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Lite POS",
  "version": "0.1.0",
  "identifier": "com.litepos.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lite POS",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "main-capability",
          "windows": ["main"],
          "permissions": [
            {
              "identifier": "http:default",
              "allow": [
                {"url": "https://device.cardknox.com/*"}
              ]
            },
            "http:allow-fetch",
            "sql:default",
            "sql:allow-load",
            "sql:allow-execute",
            "sql:allow-select"
          ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:lite-pos.db?mode=rwc&busy_timeout=5000"]
    },
    "updater": {
      "endpoints": [
        "https://github.com/{{owner}}/lite-pos/releases/latest/download/latest.json"
      ],
      "pubkey": ""
    }
  }
}
